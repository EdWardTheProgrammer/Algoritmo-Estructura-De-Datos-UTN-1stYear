#include <iostream> // Librería estándar de entrada y salida en C++

using namespace std; // Para no tener que escribir std:: antes de cada comando

int main() {
    int x;

    cout << "Por favor, introduzca un numero entero: ";
    
    // cin extrae el valor del teclado y lo guarda en x
    cin >> x; 

    cout << "Has introducido el numero " << x << ", gracias." << endl; //cout imprime. Ademas, endl es como un \n

    return 0;
}
