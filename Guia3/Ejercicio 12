#include <iostream>
using namespace std;

// Definimos el struct para agrupar los tres lados
struct Triangulo {
    float a;
    float b;
    float c;
};

// Prototipos
void ingresarLados(Triangulo &t);
void verificarTriangulo(Triangulo t);

int main() {
    Triangulo miTriangulo;

    ingresarLados(miTriangulo);
    verificarTriangulo(miTriangulo);

    return 0;
}

void ingresarLados(Triangulo &t) {
    cout << "Ingrese el valor del lado A: ";
    cin >> t.a;
    cout << "Ingrese el valor del lado B: ";
    cin >> t.b;
    cout << "Ingrese el valor del lado C: ";
    cin >> t.c;
}

void verificarTriangulo(Triangulo t) {
    // Aplicamos la propiedad: cada lado debe ser menor a la suma de los otros dos
    if ((t.a + t.b > t.c) && (t.a + t.c > t.b) && (t.b + t.c > t.a)) {
        cout << "\nForman triangulo" << endl;
    } else {
        cout << "\nNo forman triangulo" << endl;
    }
}
