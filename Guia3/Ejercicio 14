#include <iostream>
#include <string>

using namespace std;

bool esBisiesto(int anio) {
    return (anio % 4 == 0 && anio % 100 != 0) || (anio % 400 == 0);
}

int main() {
    int mes, anio;

    int diasPorMes[] = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
    string nombresMeses[] = {
        "Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
        "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"
    };

    // --- BUCLE PARA EL MES ---
    cout << "Ingrese el numero de mes (1-12): ";
    cin >> mes;

    while (mes < 1 || mes > 12) {
        cout << "Error. Ingrese un mes valido (1-12): ";
        cin >> mes;
    }

    // --- PEDIR AÑO ---
    cout << "Ingrese el año: ";
    cin >> anio;

    // Lógica de cálculo
    int cantidadDias = diasPorMes[mes - 1];

    if (mes == 2 && esBisiesto(anio)) {
        cantidadDias = 29;
    }

    cout << "El mes de " << nombresMeses[mes - 1] << " del año " << anio 
         << " tiene " << cantidadDias << " dias." << endl;

    return 0;
}
