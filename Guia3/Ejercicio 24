#include <iostream>

using namespace std;

int main() {
    int K;

    // Validación de entrada para la cantidad de equipos
    do {
        cout << "Ingrese la cantidad de equipos participantes (minimo 2): ";
        cin >> K;
        if (K < 2) {
            cout << "Numero invalido. Debe haber al menos 2 equipos." << endl;
        }
    } while (K < 2);

    /* Definimos la matriz: 
       Filas: K (una por cada equipo)
       Columnas: 2 (Col 0: ID del equipo, Col 1: Puntaje Total)
    */
    int torneo[K][2];

    // Procesamiento de datos por equipo
    for (int i = 0; i < K; i++) {
        int id, puntos = 0;
        char resultado;

        cout << "\n--- Datos del Equipo " << i + 1 << " ---" << endl;
        cout << "Ingrese el nro de equipo: ";
        cin >> id;
        
        torneo[i][0] = id; // Guardamos el ID en la primera columna

        // Cada equipo juega K-1 partidos en un todos contra todos
        cout << "Ingrese los resultados de los " << K - 1 << " partidos:" << endl;
        for (int j = 0; j < K - 1; j++) {
            do {
                cout << " Partido " << j + 1 << " (G/E/P): ";
                cin >> resultado;
                resultado = toupper(resultado); // Convertir a mayúscula por seguridad

                if (resultado == 'G') {
                    puntos += 3;
                } else if (resultado == 'E') {
                    puntos += 1;
                } else if (resultado != 'P') {
                    cout << " Codigo invalido. Use G, E o P." << endl;
                }
            } while (resultado != 'G' && resultado != 'E' && resultado != 'P');
        }
        
        torneo[i][1] = puntos; // Guardamos el puntaje final en la segunda columna
    }

    // Impresión de resultados finales
    cout << "\n===============================" << endl;
    cout << "   RESULTADOS DEL TORNEO" << endl;
    cout << "===============================" << endl;
    cout << "EQUIPO\t\tPUNTAJE TOTAL" << endl;

    for (int i = 0; i < K; i++) {
        cout << torneo[i][0] << "\t\t" << torneo[i][1] << " pts" << endl;
    }

    return 0;
}
