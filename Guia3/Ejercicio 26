#include <iostream>

using namespace std;

void procesarParidad(int n) {
    if (n % 2 == 0) cout << "   El numero " << n << " es PAR." << endl;
    else cout << "   El numero " << n << " es IMPAR." << endl;
}

void algoritmoPrecondicional() {
    int actual, anterior;

    cout << "\n--- CICLO PRECONDICIONAL (while) ---" << endl;
    cout << "Ingrese un numero positivo: ";
    cin >> actual;

    // Condición antes de entrar: el actual no puede ser igual al anterior
    // (Iniciamos anterior con un valor que no rompa el programa al inicio)
    anterior = -1; 

    while (actual != anterior) {
        if (actual > 0) {
            procesarParidad(actual);
            anterior = actual;
            cout << "Ingrese el siguiente numero (igual para salir): ";
            cin >> actual;
        } else {
            cout << "Error: Ingrese solo positivos." << endl;
            cout << "Ingrese el siguiente numero: ";
            cin >> actual;
        }
    }
    cout << "Finalizado por repeticion." << endl;
}

void algoritmoPostcondicional() {
    int actual, anterior = -1;

    cout << "\n--- CICLO POSTCONDICIONAL (do-while) ---" << endl;
    
    do {
        cout << "Ingrese un numero positivo: ";
        cin >> actual;

        if (actual == anterior) break; // Salida inmediata si es igual

        if (actual > 0) {
            procesarParidad(actual);
            anterior = actual;
        } else {
            cout << "Error: Ingrese solo positivos." << endl;
        }

    } while (true); // El control real de salida lo hace el 'if (actual == anterior)'
    
    cout << "Finalizado por repeticion." << endl;
}

int main() {
    int opcion;
    do {
        cout << "\nSeleccione algoritmo:\n1. Precondicional\n2. Postcondicional\n0. Salir\nOpcion: ";
        cin >> opcion;

        switch(opcion) {
            case 1: algoritmoPrecondicional(); break;
            case 2: algoritmoPostcondicional(); break;
        }
    } while (opcion != 0);

    return 0;
}
