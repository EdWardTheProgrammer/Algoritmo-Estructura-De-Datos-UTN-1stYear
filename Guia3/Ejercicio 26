#include <iostream>

using namespace std;

void procesarParidad(int n) {
    if (n % 2 == 0) cout << "   El numero " << n << " es PAR." << endl;
    else cout << "   El numero " << n << " es IMPAR." << endl;
}

void algoritmoPrecondicional() {
    int actual, anterior = -1; // Inicializamos anterior para la primera comparación

    cout << "\n--- CICLO PRECONDICIONAL (while) ---" << endl;
    cout << "Ingrese un numero positivo: ";
    cin >> actual;

    // La condición se evalúa ANTES de procesar
    while (actual != anterior) {
        if (actual > 0) {
            procesarParidad(actual);
            anterior = actual; // Guardamos el valor procesado como 'anterior'
            cout << "Ingrese el siguiente (igual para salir): ";
            cin >> actual;
        } else {
            cout << "Error: Ingrese solo positivos." << endl;
            cout << "Reintente: ";
            cin >> actual;
        }
    }
    cout << "Finalizado por repeticion." << endl;
}

void algoritmoPostcondicional() {
    int actual, anterior = -1;

    cout << "\n--- CICLO POSTCONDICIONAL (do-while) ---" << endl;
    
    // El ciclo se ejecuta y LUEGO evalúa la condición al final
    do {
        cout << "Ingrese un numero positivo (igual al anterior para salir): ";
        anterior = actual; // El que era 'actual' ahora es 'anterior'
        cin >> actual;

        // Solo procesamos si no es la condición de salida y es positivo
        if (actual != anterior && actual > 0) {
            procesarParidad(actual);
        } else if (actual <= 0 && actual != anterior) {
            cout << "Error: Ingrese solo positivos." << endl;
        }

    } while (actual != anterior); 
    
    cout << "Finalizado por repeticion." << endl;
}

int main() {
    int opcion;
    do {
        cout << "\nSeleccione algoritmo:\n1. Precondicional\n2. Postcondicional\n0. Salir\nOpcion: ";
        cin >> opcion;

        switch(opcion) {
            case 1: algoritmoPrecondicional(); break;
            case 2: algoritmoPostcondicional(); break;
        }
    } while (opcion != 0);

    return 0;
}
