#include <iostream>
using namespace std;

int elegirCantDeNumeros(){
	int num;
	cout << "Ingrese la cant de numeros que va a escribir: ";
	cin >> num;
	return num;
}
 
void ingresarNumeros(int n, int numeros[]){
	cout << "Ingrese valores: ";
	for(int i = 0; i < n; i++){
		cin >> numeros[i];
		
	}
}

void imprimirNumeros(int n, int numeros[]){
	for(int i = 0; i < n; i++){
	cout << numeros[i] << (i == n - 1 ? "" : " - ");
	}
}

void determinarMayorYMenor(int numeros[], int n){
	int mayor = numeros[0];
	int menor = numeros[0];
	int posicionMayor, posicionMenor;
	for(int i = 0; i < n; i++){
		if(menor > numeros[i]){
			menor = numeros[i];
			posicionMenor = i + 1;
		}
		else if (mayor < numeros[i]){
			mayor = numeros[i];
			posicionMayor = i  +  1;
		}
	}
	cout <<"En el conjunto de estos numeros: "<<endl;
	
	imprimirNumeros(n, numeros);
	
	cout <<"\nEstos fueron los resultados: "<<endl;
	
	cout <<"Mayor: "<< mayor << " Posicion: " << posicionMayor<<endl;
	cout <<"Menor: "<< menor << " Posicion: " << posicionMenor<<endl;
}

int main() {
    cout << "Bienvenido. Ingrese la cantidad de valores que escribira. Luego, vera el mayor y menor de estos junto a su posicion entre los valores" << endl;
    int n = elegirCantDeNumeros();
    int numeros[n];
    ingresarNumeros(n, numeros);
	determinarMayorYMenor(numeros, n);
    return 0;
}
